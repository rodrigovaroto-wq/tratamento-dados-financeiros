# Copie para .env.local e preencha com os valores do projeto Supabase
# (Settings → API). NEXT_PUBLIC_* fica exposto ao browser por design — é a
# chave anon/publishable, que RESPEITA RLS (nunca a service_role aqui).
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
