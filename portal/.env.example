# Copie para .env.local e preencha com os valores do projeto Supabase
# (Settings → API). NEXT_PUBLIC_* fica exposto ao browser por design — é a
# chave anon/publishable, que RESPEITA RLS (nunca a service_role aqui).
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Upload pelo portal (opcional): URL de produção do Form do N8N (node "Intake
# (Form)" → Production URL). O portal encaminha os arquivos pra cá; o pipeline
# continua no N8N. Sem isto, as páginas de upload mostram "não configurado".
N8N_INTAKE_FORM_URL=
# Opcionais — só se os rótulos dos campos do Form forem diferentes dos padrões:
# N8N_INTAKE_FIELD_MANDATO=Mandato (nome do caso)
# N8N_INTAKE_FIELD_ARQUIVOS=Arquivos
